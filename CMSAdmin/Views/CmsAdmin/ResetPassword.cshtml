@model Carrotware.CMS.Security.Models.ResetPasswordViewModel

@{
	Layout = CarrotLayout.Public;

	ViewBag.Title = "Reset password";
}

@if (Model.ValidToken) {
	using (Html.BeginForm(SiteActions.ResetPassword, CmsRouteConstants.CmsController.Admin, FormMethod.Post, new { })) {
		@Html.AntiForgeryToken()

		@Html.HiddenFor(model => model.Token)

		<div>
			@Html.LabelFor(m => m.Email, new { @class = "caption" })
			@Html.ValidationMessageFor(m => m.Email, "", new { @class = "validationError" })
			<div>
				@Html.TextBoxFor(m => m.Email, new { @class = "form-control-lg" })
			</div>
		</div>
		<div>
			@Html.LabelFor(m => m.Password, new { @class = "caption" })
			@Html.ValidationMessageFor(m => m.Password, "", new { @class = "validationError" })
			<div>
				@Html.PasswordFor(m => m.Password, new { @class = "form-control-md" })
			</div>
		</div>
		<div>
			@Html.LabelFor(m => m.ConfirmPassword, new { @class = "caption" })
			@Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "validationError" })
			<div>
				@Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control-md" })
			</div>
		</div>
		<br />

		@Html.Partial("_PublicValidError")
		<div>
			<div>
				<input type="submit" value="Reset" />
			</div>
		</div>
	}
	<p>
		<a href="@SiteFilename.LoginURL">Login</a>
	</p>
} else {
	<p>
		Your reset link is invalid or has expired.  Please request a new link.
	</p>
	<p>
		<a href="@SiteFilename.ForgotPasswordURL" id="lnkForgot">Forgot Password?</a>
	</p>
}
